PORT=5002

# Comma-separated allowed frontend origins (must match where users open the app)
# Local:  http://localhost:3001
# Render: https://your-service-name.onrender.com
CLIENT_ORIGIN=http://localhost:3001

MONGO_URL="mongodb://localhost:27017/chat"

# Public URL clients use to reach this server (REST, Socket.IO, uploaded files)
# Local:  http://localhost:5002
# Render: https://your-service-name.onrender.com
SERVER_URL=http://localhost:5002

# Set automatically on Render — do not set locally unless testing production build
# NODE_ENV=production

# Brevo (recommended for production / Render — HTTPS API, no SMTP ports needed)
# 1. Sign up at https://brevo.com
# 2. Profile → SMTP & API → API Keys → Generate a new API key
# 3. Add BREVO_FROM_EMAIL as a verified sender in Brevo
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=your@gmail.com
BREVO_FROM_NAME=LetzChat

# Gmail SMTP (local development fallback only — Render blocks SMTP ports 587/465)
# 1. Enable 2-Step Verification on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM="LetzChat <your@gmail.com>"
