REACT_APP_LOCALHOST_KEY="chat-app-current-user"

# Frontend dev server port (must match server CLIENT_ORIGIN)
PORT=3001

# Backend URL — use your public IP, domain, or tunnel URL for cross-network access
# Examples:
#   Local:     http://localhost:5002
#   LAN:       http://192.168.1.100:5002
#   Tunnel:    https://your-subdomain.ngrok-free.app
REACT_APP_API_HOST=http://localhost:5002

# WebRTC ICE servers (optional JSON array). Default uses Google STUN.
# REACT_APP_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]

# TURN server for calls across strict NATs / different networks (recommended for production)
# REACT_APP_TURN_URL=turn:your-turn-server.com:3478
# REACT_APP_TURN_USERNAME=your-turn-user
# REACT_APP_TURN_CREDENTIAL=your-turn-password
